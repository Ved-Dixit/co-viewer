# Oracle Cloud Database Credentials
# Get these from your Oracle Cloud Console -> Autonomous Database -> DB Connection (TLS)

DB_USER=admin
DB_PASSWORD=your_strong_password
DB_CONNECTION_STRING="(description= (retry_count=20)(retry_delay=3)(address=(protocol=tcps)(port=1521)(host=adb.region.oraclecloud.com))(connect_data=(service_name=yourdb_high.adb.oraclecloud.com))(security=(ssl_server_dn_match=yes)))"

# Signaling Server Port
PORT=8080
